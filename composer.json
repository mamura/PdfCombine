{
  "name": "mamura/pdf-combine",
  "description": "Package for combining PDF files in PHP",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Mamura\\PdfCombine\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mamura\\PdfCombine\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "setasign/fpdf": "^1.8",
    "setasign/fpdi": "^2.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "orchestra/testbench": "^10.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Mamura\\PdfCombine\\Laravel\\PdfCombineServiceProvider"
      ],
      "aliases": {
        "PdfCombine": "Mamura\\PdfCombine\\Laravel\\Facades\\PdfCombine"
      }
    }
  },
    "minimum-stability": "stable",
    "prefer-stable": true
}